# ==============================
# GenScape 环境变量配置
# 复制此文件为 .env 并填入你的 API Key:
# cp .env.example .env
# ==============================

# AI 提供商选择: deepseek | claude
VITE_AI_PROVIDER=deepseek

# DeepSeek API Key (需要在 https://platform.deepseek.com 获取)
VITE_DEEPSEEK_API_KEY=sk-your-deepseek-key

# DeepSeek API 地址 (可选，默认值如下)
# VITE_DEEPSEEK_BASE_URL=https://api.deepseek.com

# Claude API Key (需要在 https://console.anthropic.com 获取)
# VITE_CLAUDE_API_KEY=sk-ant-your-claude-key

# 应用信息
VITE_APP_TITLE=GenScape
VITE_APP_VERSION=0.1.0
